<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Colivex Admin Réservations</title>
  <style>
    :root{
      --red:#d71920;
      --blue:#0b3b8c;
      --light:#f5f7fb;
      --dark:#1f2937;
      --gray:#6b7280;
      --border:#dbe3ef;
      --white:#ffffff;
      --green:#16a34a;
      --orange:#ea580c;
      --yellow:#ca8a04;
      --purple:#7c3aed;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:var(--light);
      color:var(--dark);
    }

    .topbar{
      background:linear-gradient(90deg,var(--blue),var(--red));
      color:#fff;
      padding:18px 20px;
      font-size:24px;
      font-weight:700;
      letter-spacing:.3px;
    }

    .container{
      max-width:1400px;
      margin:20px auto;
      padding:0 16px 30px;
    }

    .grid{
      display:grid;
      grid-template-columns:420px 1fr;
      gap:20px;
    }

    .card{
      background:var(--white);
      border:1px solid var(--border);
      border-radius:18px;
      box-shadow:0 8px 24px rgba(0,0,0,.06);
      overflow:hidden;
    }

    .card-header{
      padding:16px 18px;
      font-size:18px;
      font-weight:700;
      color:#fff;
      background:linear-gradient(90deg,var(--red),var(--blue));
    }

    .card-body{
      padding:16px;
    }

    .form-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    .form-group{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .form-group.full{
      grid-column:1 / -1;
    }

    label{
      font-size:13px;
      font-weight:700;
      color:var(--blue);
    }

    input, select, textarea{
      width:100%;
      padding:12px 12px;
      border:1px solid var(--border);
      border-radius:12px;
      font-size:14px;
      outline:none;
      background:#fff;
    }

    input:focus, select:focus, textarea:focus{
      border-color:var(--blue);
      box-shadow:0 0 0 3px rgba(11,59,140,.12);
    }

    textarea{
      min-height:90px;
      resize:vertical;
    }

    .btn-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:16px;
    }

    button{
      border:none;
      cursor:pointer;
      border-radius:12px;
      padding:12px 16px;
      font-size:14px;
      font-weight:700;
    }

    .btn-primary{
      background:var(--red);
      color:#fff;
    }

    .btn-secondary{
      background:var(--blue);
      color:#fff;
    }

    .btn-light{
      background:#eef3ff;
      color:var(--blue);
    }

    .btn-danger{
      background:#fee2e2;
      color:#b91c1c;
    }

    .toolbar{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:16px;
      align-items:center;
    }

    .toolbar input, .toolbar select{
      max-width:240px;
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px;
      margin-bottom:16px;
    }

    .stat{
      padding:14px;
      border-radius:16px;
      color:#fff;
      font-weight:700;
      min-height:90px;
      display:flex;
      flex-direction:column;
      justify-content:center;
      gap:6px;
    }

    .stat .big{
      font-size:28px;
      line-height:1;
    }

    .bg-blue{background:var(--blue)}
    .bg-red{background:var(--red)}
    .bg-green{background:var(--green)}
    .bg-orange{background:var(--orange)}

    .schedule-wrap{
      overflow:auto;
      border:1px solid var(--border);
      border-radius:16px;
    }

    table{
      width:100%;
      border-collapse:collapse;
      min-width:980px;
      background:#fff;
    }

    th, td{
      padding:12px 10px;
      border-bottom:1px solid #e8edf5;
      vertical-align:top;
      text-align:left;
      font-size:14px;
    }

    th{
      background:#f8fafc;
      color:var(--blue);
      position:sticky;
      top:0;
      z-index:1;
    }

    .slot-badge{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:700;
      color:#fff;
      background:var(--blue);
      white-space:nowrap;
    }

    .status{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:700;
      color:#fff;
      white-space:nowrap;
    }

    .status-demande{background:var(--yellow)}
    .status-confirme{background:var(--blue)}
    .status-depot{background:var(--green)}
    .status-termine{background:var(--purple)}
    .status-annule{background:#9ca3af}

    .reservation-card{
      border:1px solid var(--border);
      border-radius:14px;
      padding:12px;
      margin-bottom:10px;
      background:#fff;
    }

    .reservation-top{
      display:flex;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:8px;
    }

    .reservation-name{
      font-weight:700;
      font-size:16px;
      color:var(--dark);
    }

    .small{
      font-size:12px;
      color:var(--gray);
    }

    .actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .empty{
      text-align:center;
      padding:26px;
      color:var(--gray);
      font-weight:700;
    }

    .section-title{
      margin:0 0 12px;
      font-size:18px;
      color:var(--blue);
    }

    @media (max-width: 1100px){
      .grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 700px){
      .form-grid,
      .stats{
        grid-template-columns:1fr;
      }
      .toolbar{
        flex-direction:column;
        align-items:stretch;
      }
      .toolbar input, .toolbar select{
        max-width:none;
      }
    }
  </style>
</head>
<body>
  <div class="topbar">Transport Colivex — Administration Réservations</div>

  <div class="container">
    <div class="grid">
      <div class="card">
        <div class="card-header">Nouvelle réservation / Modifier</div>
        <div class="card-body">
          <form id="bookingForm">
            <input type="hidden" id="bookingId" />

            <div class="form-grid">
              <div class="form-group">
                <label for="clientName">Nom du client</label>
                <input type="text" id="clientName" required />
              </div>

              <div class="form-group">
                <label for="phone">Téléphone</label>
                <input type="text" id="phone" required />
              </div>

              <div class="form-group">
                <label for="email">Courriel</label>
                <input type="email" id="email" />
              </div>

              <div class="form-group">
                <label for="date">Date</label>
                <input type="date" id="date" required />
              </div>

              <div class="form-group">
                <label for="slot">Plage camion</label>
                <select id="slot" required>
                  <option value="">Choisir</option>
                  <option>Camion 1 AM</option>
                  <option>Camion 1 PM</option>
                  <option>Camion 2 AM</option>
                  <option>Camion 2 PM</option>
                  <option>Camion 3 AM</option>
                  <option>Camion 3 PM</option>
                  <option>Camion 4 AM</option>
                  <option>Camion 4 PM</option>
                  <option>Camion 5 AM</option>
                  <option>Camion 5 PM</option>
                </select>
              </div>

              <div class="form-group">
                <label for="status">Statut</label>
                <select id="status" required>
                  <option value="Demande">Demande</option>
                  <option value="Confirmé">Confirmé</option>
                  <option value="Dépôt reçu">Dépôt reçu</option>
                  <option value="Terminé">Terminé</option>
                  <option value="Annulé">Annulé</option>
                </select>
              </div>

              <div class="form-group">
                <label for="deposit">Dépôt ($)</label>
                <input type="number" id="deposit" placeholder="250" />
              </div>

              <div class="form-group">
                <label for="movers">Nombre de déménageurs</label>
                <input type="number" id="movers" min="1" placeholder="3" />
              </div>

              <div class="form-group full">
                <label for="pickup">Adresse départ</label>
                <input type="text" id="pickup" />
              </div>

              <div class="form-group full">
                <label for="dropoff">Adresse arrivée</label>
                <input type="text" id="dropoff" />
              </div>

              <div class="form-group">
                <label for="housing">Type / grandeur</label>
                <input type="text" id="housing" placeholder="4 1/2, 5 1/2, maison..." />
              </div>

              <div class="form-group">
                <label for="rate">Tarif ($/h)</label>
                <input type="number" id="rate" placeholder="165" />
              </div>

              <div class="form-group full">
                <label for="notes">Notes internes</label>
                <textarea id="notes" placeholder="Ascenseur, dépôt, matériel, remarques..."></textarea>
              </div>
            </div>

            <div class="btn-row">
              <button type="submit" class="btn-primary">Enregistrer</button>
              <button type="button" class="btn-secondary" id="resetBtn">Vider</button>
              <button type="button" class="btn-light" id="demoBtn">Ajouter données test</button>
            </div>
          </form>
        </div>
      </div>

      <div>
        <div class="stats">
          <div class="stat bg-blue">
            <div>Réservations</div>
            <div class="big" id="statTotal">0</div>
          </div>
          <div class="stat bg-red">
            <div>Confirmées</div>
            <div class="big" id="statConfirmed">0</div>
          </div>
          <div class="stat bg-green">
            <div>Dépôts reçus</div>
            <div class="big" id="statDeposit">0</div>
          </div>
          <div class="stat bg-orange">
            <div>Aujourd’hui</div>
            <div class="big" id="statToday">0</div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">Calendrier / Liste admin</div>
          <div class="card-body">
            <div class="toolbar">
              <input type="text" id="searchInput" placeholder="Recherche nom, téléphone, adresse..." />
              <input type="date" id="filterDate" />
              <select id="filterStatus">
                <option value="">Tous les statuts</option>
                <option>Demande</option>
                <option>Confirmé</option>
                <option>Dépôt reçu</option>
                <option>Terminé</option>
                <option>Annulé</option>
              </select>
              <button class="btn-light" id="clearFilters">Effacer filtres</button>
            </div>

            <h3 class="section-title">Vue calendrier simplifiée</h3>
            <div class="schedule-wrap">
              <table id="calendarTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Plage camion</th>
                    <th>Client</th>
                    <th>Téléphone</th>
                    <th>Départ</th>
                    <th>Arrivée</th>
                    <th>Statut</th>
                    <th>Dépôt</th>
                  </tr>
                </thead>
                <tbody id="calendarBody"></tbody>
              </table>
            </div>

            <h3 class="section-title" style="margin-top:18px;">Fiches réservations</h3>
            <div id="cardsContainer"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const STORAGE_KEY = "colivex_admin_bookings_v1";

    const bookingForm = document.getElementById("bookingForm");
    const bookingId = document.getElementById("bookingId");
    const clientName = document.getElementById("clientName");
    const phone = document.getElementById("phone");
    const email = document.getElementById("email");
    const date = document.getElementById("date");
    const slot = document.getElementById("slot");
    const status = document.getElementById("status");
    const deposit = document.getElementById("deposit");
    const movers = document.getElementById("movers");
    const pickup = document.getElementById("pickup");
    const dropoff = document.getElementById("dropoff");
    const housing = document.getElementById("housing");
    const rate = document.getElementById("rate");
    const notes = document.getElementById("notes");

    const searchInput = document.getElementById("searchInput");
    const filterDate = document.getElementById("filterDate");
    const filterStatus = document.getElementById("filterStatus");
    const clearFilters = document.getElementById("clearFilters");
    const resetBtn = document.getElementById("resetBtn");
    const demoBtn = document.getElementById("demoBtn");

    const calendarBody = document.getElementById("calendarBody");
    const cardsContainer = document.getElementById("cardsContainer");

    const statTotal = document.getElementById("statTotal");
    const statConfirmed = document.getElementById("statConfirmed");
    const statDeposit = document.getElementById("statDeposit");
    const statToday = document.getElementById("statToday");

    function getBookings() {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
    }

    function saveBookings(bookings) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(bookings));
    }

    function formatMoney(value) {
      const n = Number(value || 0);
      return n.toLocaleString("fr-CA", { style: "currency", currency: "CAD" });
    }

    function escapeHtml(str) {
      return (str || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function statusClass(value) {
      if (value === "Demande") return "status-demande";
      if (value === "Confirmé") return "status-confirme";
      if (value === "Dépôt reçu") return "status-depot";
      if (value === "Terminé") return "status-termine";
      return "status-annule";
    }

    function isConflict(currentId, selectedDate, selectedSlot) {
      const bookings = getBookings();
      return bookings.some(item =>
        item.date === selectedDate &&
        item.slot === selectedSlot &&
        item.id !== currentId &&
        item.status !== "Annulé"
      );
    }

    function resetForm() {
      bookingForm.reset();
      bookingId.value = "";
      status.value = "Demande";
    }

    function sortBookings(list) {
      return [...list].sort((a, b) => {
        if (a.date !== b.date) return a.date.localeCompare(b.date);
        return a.slot.localeCompare(b.slot);
      });
    }

    function getFilteredBookings() {
      const bookings = sortBookings(getBookings());
      const q = searchInput.value.trim().toLowerCase();
      const d = filterDate.value;
      const s = filterStatus.value;

      return bookings.filter(item => {
        const haystack = [
          item.clientName,
          item.phone,
          item.email,
          item.pickup,
          item.dropoff,
          item.housing,
          item.notes,
          item.slot
        ].join(" ").toLowerCase();

        const matchesSearch = !q || haystack.includes(q);
        const matchesDate = !d || item.date === d;
        const matchesStatus = !s || item.status === s;

        return matchesSearch && matchesDate && matchesStatus;
      });
    }

    function renderStats() {
      const bookings = getBookings();
      const today = new Date().toISOString().split("T")[0];

      statTotal.textContent = bookings.length;
      statConfirmed.textContent = bookings.filter(b => b.status === "Confirmé").length;
      statDeposit.textContent = bookings.filter(b => b.status === "Dépôt reçu").length;
      statToday.textContent = bookings.filter(b => b.date === today).length;
    }

    function renderTable() {
      const rows = getFilteredBookings();

      if (!rows.length) {
        calendarBody.innerHTML = `
          <tr>
            <td colspan="8" class="empty">Aucune réservation trouvée</td>
          </tr>
        `;
        return;
      }

      calendarBody.innerHTML = rows.map(item => `
        <tr>
          <td>${escapeHtml(item.date)}</td>
          <td><span class="slot-badge">${escapeHtml(item.slot)}</span></td>
          <td>${escapeHtml(item.clientName)}</td>
          <td>${escapeHtml(item.phone)}</td>
          <td>${escapeHtml(item.pickup || "-")}</td>
          <td>${escapeHtml(item.dropoff || "-")}</td>
          <td><span class="status ${statusClass(item.status)}">${escapeHtml(item.status)}</span></td>
          <td>${formatMoney(item.deposit)}</td>
        </tr>
      `).join("");
    }

    function renderCards() {
      const rows = getFilteredBookings();

      if (!rows.length) {
        cardsContainer.innerHTML = `<div class="empty">Aucune fiche à afficher</div>`;
        return;
      }

      cardsContainer.innerHTML = rows.map(item => `
        <div class="reservation-card">
          <div class="reservation-top">
            <div>
              <div class="reservation-name">${escapeHtml(item.clientName)}</div>
              <div class="small">${escapeHtml(item.date)} • ${escapeHtml(item.slot)}</div>
            </div>
            <div>
              <span class="status ${statusClass(item.status)}">${escapeHtml(item.status)}</span>
            </div>
          </div>

          <div><strong>Téléphone :</strong> ${escapeHtml(item.phone || "-")}</div>
          <div><strong>Courriel :</strong> ${escapeHtml(item.email || "-")}</div>
          <div><strong>Départ :</strong> ${escapeHtml(item.pickup || "-")}</div>
          <div><strong>Arrivée :</strong> ${escapeHtml(item.dropoff || "-")}</div>
          <div><strong>Logement :</strong> ${escapeHtml(item.housing || "-")}</div>
          <div><strong>Déménageurs :</strong> ${escapeHtml(item.movers || "-")}</div>
          <div><strong>Tarif :</strong> ${item.rate ? formatMoney(item.rate) + "/h" : "-"}</div>
          <div><strong>Dépôt :</strong> ${formatMoney(item.deposit)}</div>
          <div><strong>Notes :</strong> ${escapeHtml(item.notes || "-")}</div>

          <div class="actions">
            <button class="btn-secondary" onclick="editBooking('${item.id}')">Modifier</button>
            <button class="btn-danger" onclick="deleteBooking('${item.id}')">Supprimer</button>
          </div>
        </div>
      `).join("");
    }

    function renderAll() {
      renderStats();
      renderTable();
      renderCards();
    }

    bookingForm.addEventListener("submit", function(e) {
      e.preventDefault();

      const currentId = bookingId.value || crypto.randomUUID();

      if (isConflict(currentId, date.value, slot.value)) {
        alert("Conflit: cette plage camion est déjà réservée à cette date.");
        return;
      }

      const payload = {
        id: currentId,
        clientName: clientName.value.trim(),
        phone: phone.value.trim(),
        email: email.value.trim(),
        date: date.value,
        slot: slot.value,
        status: status.value,
        deposit: Number(deposit.value || 0),
        movers: movers.value.trim(),
        pickup: pickup.value.trim(),
        dropoff: dropoff.value.trim(),
        housing: housing.value.trim(),
        rate: Number(rate.value || 0),
        notes: notes.value.trim(),
        updatedAt: new Date().toISOString()
      };

      const bookings = getBookings();
      const existingIndex = bookings.findIndex(b => b.id === currentId);

      if (existingIndex >= 0) {
        bookings[existingIndex] = payload;
      } else {
        bookings.push(payload);
      }

      saveBookings(bookings);
      resetForm();
      renderAll();
    });

    resetBtn.addEventListener("click", resetForm);

    clearFilters.addEventListener("click", () => {
      searchInput.value = "";
      filterDate.value = "";
      filterStatus.value = "";
      renderAll();
    });

    [searchInput, filterDate, filterStatus].forEach(el => {
      el.addEventListener("input", renderAll);
      el.addEventListener("change", renderAll);
    });

    demoBtn.addEventListener("click", () => {
      const sample = [
        {
          id: crypto.randomUUID(),
          clientName: "Mme Gagnon",
          phone: "514-555-0101",
          email: "client1@email.com",
          date: "2026-04-03",
          slot: "Camion 1 AM",
          status: "Confirmé",
          deposit: 250,
          movers: 3,
          pickup: "Laval",
          dropoff: "Blainville",
          housing: "5 1/2",
          rate: 165,
          notes: "Ascenseur destination",
          updatedAt: new Date().toISOString()
        },
        {
          id: crypto.randomUUID(),
          clientName: "M. Dufresne",
          phone: "514-555-0102",
          email: "client2@email.com",
          date: "2026-04-03",
          slot: "Camion 2 AM",
          status: "Dépôt reçu",
          deposit: 300,
          movers: 3,
          pickup: "Montréal",
          dropoff: "Laval",
          housing: "Maison",
          rate: 175,
          notes: "Piano non inclus",
          updatedAt: new Date().toISOString()
        },
        {
          id: crypto.randomUUID(),
          clientName: "Mme Bouchard",
          phone: "514-555-0103",
          email: "client3@email.com",
          date: "2026-04-04",
          slot: "Camion 1 PM",
          status: "Demande",
          deposit: 0,
          movers: 2,
          pickup: "Repentigny",
          dropoff: "Terrebonne",
          housing: "4 1/2",
          rate: 135,
          notes: "2e étage sans ascenseur",
          updatedAt: new Date().toISOString()
        }
      ];

      saveBookings(sample);
      renderAll();
    });

    window.editBooking = function(id) {
      const bookings = getBookings();
      const item = bookings.find(b => b.id === id);
      if (!item) return;

      bookingId.value = item.id;
      clientName.value = item.clientName || "";
      phone.value = item.phone || "";
      email.value = item.email || "";
      date.value = item.date || "";
      slot.value = item.slot || "";
      status.value = item.status || "Demande";
      deposit.value = item.deposit || "";
      movers.value = item.movers || "";
      pickup.value = item.pickup || "";
      dropoff.value = item.dropoff || "";
      housing.value = item.housing || "";
      rate.value = item.rate || "";
      notes.value = item.notes || "";

      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    window.deleteBooking = function(id) {
      if (!confirm("Supprimer cette réservation ?")) return;
      const bookings = getBookings().filter(b => b.id !== id);
      saveBookings(bookings);
      renderAll();
      if (bookingId.value === id) resetForm();
    };

    renderAll();
  </script>
</body>
</html>